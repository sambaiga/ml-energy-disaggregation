# ----------------------------------------------------------------------
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
junit.xml # Added common CI test report
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
.ruff_cache/
pytestdebug.log
cover/


# ----------------------------------------------------------------------
# Documentation & Notebooks
# ----------------------------------------------------------------------
