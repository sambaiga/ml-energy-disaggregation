# ----------------------------------------------------------------------
# Python-generated files (Ignore all compiled/temporary Python artifacts)
# ----------------------------------------------------------------------
__pycache__/
*.py[co]
build/
dist/
wheels/
*.egg-info
.pypirc


# ----------------------------------------------------------------------
# Virtual environments (Standard ignore for local environments)
# ----------------------------------------------------------------------
.venv/
venv/
env/
# uv
# uv.lock  <-- RECOMMENDED: KEEP this file in version control for reproducibility.
# PEP 582
__pypackages__/


# ----------------------------------------------------------------------
# Build/Installer Files
# ----------------------------------------------------------------------
# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt


