*.DS_Store
*.log


# ----------------------------------------------------------------------
# Serialised ML models (generated during notebook execution)
# ----------------------------------------------------------------------
*.joblib
*.pkl
*.pickle
models/

# ----------------------------------------------------------------------
# Source materials (slides, papers, personal notes - not for distribution)
# ----------------------------------------------------------------------
sermon/

# ----------------------------------------------------------------------
# Data Files (Customize based on project needs)
# ----------------------------------------------------------------------
# IGNORE ALL data in this directory (assuming it's transient or external)
data/

# Exception: curated, versioned fixture data for tutorials, small enough to
# commit and needed for notebooks to run immediately after a fresh clone.
# Add specific tutorial data directories here as chapters are built, e.g.:
# !tutorials/01-basics/data/

# Alternative: Ignore specific generated directories
# data/processed/
# data/output/

/.quarto/
**/*.quarto_ipynb
/_book/

# _freeze/ is committed: CI uses quarto render --no-execute, reading from this cache

# Rendered HTML artefacts emitted by quarto render on individual notebooks/QMD
tutorials/**/*.html
tutorials/**/*_files/

# Local Claude Code memory and project instructions
.claude/
CLAUDE.md

resources/*

# OpenDSS auto-writes a monitor CSV (<Circuit>_Mon_<name>_<n>.csv) to the
# working directory on solve whenever a Monitor object exists, independent
# of any explicit `export` command. Stray output from this book's OpenDSS
# notebooks (Parts 4-7), not something to commit.
*_Mon_*.csv

# PyTorch Lightning auto-writes a lightning_logs/ (TensorBoard event files,
# checkpoints) next to the working directory on every .fit() call, from
# Part 8's own MLPGAM training notebooks. Build artifacts, not content.
logs/
lightning_logs/
